# =============================================================================
# SBI VISHWAS — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all required values.
# NEVER commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
APP_NAME=sbi-vishwas
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=  # Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# -----------------------------------------------------------------------------
# DATABASE — PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=sbi_vishwas
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_SSL_MODE=prefer
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false
# Constructed URL (override if using managed DB)
DATABASE_URL=postgresql+asyncpg://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL=false
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# Celery-specific Redis DB
CELERY_BROKER_DB=1
CELERY_RESULT_DB=2
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${CELERY_BROKER_DB}
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${CELERY_RESULT_DB}

# -----------------------------------------------------------------------------
# QDRANT — Vector Database
# -----------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=sbi_vishwas_knowledge
QDRANT_MEMORY_COLLECTION=sbi_vishwas_memory
QDRANT_VECTOR_SIZE=768

# -----------------------------------------------------------------------------
# AI PROVIDERS
# -----------------------------------------------------------------------------
# Default provider: gemini | openai | anthropic | ollama
AI_DEFAULT_PROVIDER=gemini
AI_DEFAULT_MODEL=gemini-2.5-flash
AI_TEMPERATURE=0.1
AI_MAX_TOKENS=4096
AI_TIMEOUT_SECONDS=60
AI_MAX_RETRIES=3

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_ORG_ID=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama (Local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# -----------------------------------------------------------------------------
# EMBEDDING
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=768
EMBEDDING_BATCH_SIZE=100

# -----------------------------------------------------------------------------
# JWT / AUTH
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=  # Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=sbi-vishwas

# OAuth (optional)
OAUTH_PROVIDER=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=

# -----------------------------------------------------------------------------
# ENCRYPTION
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=  # 32-byte base64 key. Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PII_ENCRYPTION_KEY=  # Separate key for PII. Same generation method.

# -----------------------------------------------------------------------------
# EMAIL / SMTP
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@sbi.co.in
SMTP_FROM_NAME=SBI Vishwas

# Email API (alternative to SMTP)
EMAIL_PROVIDER=smtp  # smtp | sendgrid | ses
SENDGRID_API_KEY=
AWS_SES_REGION=
AWS_SES_ACCESS_KEY=
AWS_SES_SECRET_KEY=

# -----------------------------------------------------------------------------
# SMS
# -----------------------------------------------------------------------------
SMS_PROVIDER=  # twilio | msg91 | aws_sns
SMS_FROM_NUMBER=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# MSG91
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_ROUTE=

# AWS SNS
AWS_SNS_REGION=
AWS_SNS_ACCESS_KEY=
AWS_SNS_SECRET_KEY=

# -----------------------------------------------------------------------------
# WHATSAPP
# -----------------------------------------------------------------------------
WHATSAPP_PROVIDER=  # meta | twilio
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# OCR / DOCUMENT PROCESSING
# -----------------------------------------------------------------------------
OCR_PROVIDER=  # google_vision | tesseract | azure
GOOGLE_VISION_CREDENTIALS_PATH=
AZURE_VISION_ENDPOINT=
AZURE_VISION_KEY=

# -----------------------------------------------------------------------------
# CBS (CORE BANKING SYSTEM)
# -----------------------------------------------------------------------------
CBS_BASE_URL=
CBS_API_KEY=
CBS_API_SECRET=
CBS_TIMEOUT_SECONDS=30
CBS_MAX_RETRIES=3
CBS_CERT_PATH=
CBS_CERT_KEY_PATH=

# -----------------------------------------------------------------------------
# KYC VERIFICATION
# -----------------------------------------------------------------------------
KYC_PROVIDER=  # digio | karza | signzy
KYC_API_URL=
KYC_API_KEY=
KYC_API_SECRET=

# Aadhaar eKYC
AADHAAR_API_URL=
AADHAAR_API_KEY=
AADHAAR_LICENSE_KEY=

# PAN Verification
PAN_API_URL=
PAN_API_KEY=

# -----------------------------------------------------------------------------
# GST VERIFICATION
# -----------------------------------------------------------------------------
GST_API_URL=
GST_API_KEY=

# -----------------------------------------------------------------------------
# ACCOUNT AGGREGATOR
# -----------------------------------------------------------------------------
AA_BASE_URL=
AA_CLIENT_ID=
AA_CLIENT_SECRET=
AA_FIP_ID=
AA_LICENSE_KEY=

# -----------------------------------------------------------------------------
# STORAGE
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=local  # local | s3 | gcs
STORAGE_LOCAL_PATH=./storage

# AWS S3
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=

# Google Cloud Storage
GCS_BUCKET=
GCS_CREDENTIALS_PATH=

# -----------------------------------------------------------------------------
# KAFKA (optional — event streaming)
# -----------------------------------------------------------------------------
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SSL_CAFILE=
KAFKA_CONSUMER_GROUP=sbi-vishwas-consumers

# Kafka Topics
KAFKA_TOPIC_BANKING_EVENTS=banking.events
KAFKA_TOPIC_AGENT_EVENTS=agent.events
KAFKA_TOPIC_NOTIFICATIONS=notifications
KAFKA_TOPIC_AUDIT=audit.log

# -----------------------------------------------------------------------------
# OBSERVABILITY
# -----------------------------------------------------------------------------
# OpenTelemetry
OTEL_ENABLED=true
OTEL_SERVICE_NAME=sbi-vishwas
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# Logging
LOG_FORMAT=json  # json | text
LOG_FILE_PATH=./logs/sbi-vishwas.log
LOG_ROTATION=10MB
LOG_RETENTION=30

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_AI=30/minute
RATE_LIMIT_STORAGE=redis

# -----------------------------------------------------------------------------
# SBI-SPECIFIC CONFIGURATION
# -----------------------------------------------------------------------------
SBI_BRANCH_CODE=
SBI_REGION_CODE=
SBI_IFSC_PREFIX=SBIN

# SLA Configuration (in hours)
SLA_COMPLAINT_ACKNOWLEDGMENT=1
SLA_COMPLAINT_RESOLUTION=168  # 7 days
SLA_ESCALATION_LEVEL1=48
SLA_ESCALATION_LEVEL2=96
SLA_ESCALATION_OMBUDSMAN=336  # 14 days

# Agent Configuration
AGENT_DEFAULT_CONFIDENCE_THRESHOLD=0.85
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=120
AGENT_HUMAN_APPROVAL_REQUIRED=true

# Dormancy Configuration
DORMANCY_INACTIVE_MONTHS=24
DORMANCY_SCAN_BATCH_SIZE=1000
DORMANCY_READINESS_THRESHOLD=0.70

# Credit Readiness
CREDIT_READINESS_MIN_SCORE=0.65
CREDIT_MAX_TICKET_SIZE=50000
CREDIT_APPROVAL_REQUIRED=true

# -----------------------------------------------------------------------------
# FRONTEND
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_NAME=SBI Vishwas
NEXT_PUBLIC_APP_DESCRIPTION=Autonomous Banking Operating System
